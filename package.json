{
  "name": "codex-usage-desktop",
  "version": "0.2.0",
  "private": true,
  "description": "Local Codex token and API cost analyzer",
  "author": "jiangxiaoxu",
  "license": "MIT",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-static.mjs",
    "start": "npm run build && electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/*.test.js",
    "package:portable": "npm run build && electron-builder --win portable",
    "package:installer": "npm run build && electron-builder --win nsis && node scripts/verify-nsis-installer.mjs",
    "migrate:ledger": "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File scripts/migrate-usage-ledger.ps1",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "portable:restart": "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File scripts/package-portable-and-restart.ps1",
    "package:portable:restart": "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File scripts/package-portable-and-restart.ps1 -Rebuild"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "typescript": "7.0.2"
  },
  "build": {
    "appId": "local.codex.usage.desktop",
    "productName": "Codex Usage Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.test.js",
      "!dist/**/*.test.js.map",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052",
      "include": "build/custom-installer.nsh"
    }
  },
  "dependencies": {
    "chokidar": "^4.0.3"
  }
}
